{
  "name": "InventoryManagement",
  "version": "1.0.0",
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap-cloud-sdk/connectivity": "^4.6.0",
    "@sap-cloud-sdk/http-client": "^4.6.0",
    "@sap-cloud-sdk/resilience": "^4.6.0",
    "@sap/cds": "^9",
    "axios": "^1.16.0",
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2",
    "@sap/cds-dk": "^9",
    "cds-plugin-ui5": "^0.13.0",
    "mbt": "^1.2.29",
    "rimraf": "^5.0.5"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-inventoryapp14": "cds watch --open inventoryapp14/index.html?sap-ui-xx-viewCache=false --livereload false",
    "undeploy": "cf undeploy InventoryManagement --delete-services --delete-service-keys --delete-service-brokers",
    "build": "rimraf resources mta_archives && mbt build --mtar archive",
    "deploy": "cf deploy mta_archives/archive.mtar --retries 1"
  },
  "private": true,
  "cds": {
    "requires": {
      "destinations": true,
      "numberTrigger": {
        "kind": "odata",
        "credentials": {
          "destination": "numberTrigger"
        }
      },
      "db": "hana",
      "auth": "xsuaa",
      "xsuaa": {
      "kind": "xsuaa"
    }
    }
  },
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/inventoryapp14"
  ]
}
